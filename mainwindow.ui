           <layout class="QVBoxLayout"><property name="margin"><number>10</number></property>
            <item>
             <widget class="QGroupBox"><property name="title"><string>Request Event (CGPA &gt; 3.5 required | Max 3 per group)</string></property>
              <layout class="QGridLayout">
               <item row="0" column="0"><widget class="QLabel"><property name="text"><string>Group ID</string></property></widget></item>
               <item row="0" column="1"><widget class="QLineEdit" name="txtEventGroupId"><property name="placeholderText"><string>Your group ID</string></property></widget></item>
               <item row="1" column="0"><widget class="QLabel"><property name="text"><string>Title</string></property></widget></item>
               <item row="1" column="1"><widget class="QLineEdit" name="txtEventTitle"><property name="placeholderText"><string>Event title</string></property></widget></item>
               <item row="2" column="0"><widget class="QLabel"><property name="text"><string>Date</string></property></widget></item>
               <item row="2" column="1"><widget class="QLineEdit" name="txtEventDate"><property name="placeholderText"><string>yyyy-MM-dd</string></property></widget></item>
               <item row="3" column="0"><widget class="QLabel"><property name="text"><string>Time</string></property></widget></item>
               <item row="3" column="1"><widget class="QLineEdit" name="txtEventTime"><property name="placeholderText"><string>HH:mm</string></property></widget></item>
