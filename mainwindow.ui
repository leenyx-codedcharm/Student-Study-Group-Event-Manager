               <item row="5" column="1"><widget class="QLineEdit" name="txtEventDesc"><property name="placeholderText"><string>Brief description</string></property></widget></item>
               <item row="6" column="0"><widget class="QLabel"><property name="text"><string>Priority</string></property></widget></item>
               <item row="6" column="1"><widget class="QComboBox" name="cmbEventPriority"><item><property name="text"><string>High</string></property></item><item><property name="text"><string>Medium</string></property></item><item><property name="text"><string>Low</string></property></item></widget></item>
              </layout>
