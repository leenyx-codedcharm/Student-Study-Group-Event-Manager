          <!-- TAB: Admin Create Group -->
          <widget class="QWidget" name="tabAdminCreateGroup"><attribute name="title"><string>➕ Create Group</string></attribute>
           <layout class="QVBoxLayout"><property name="margin"><number>14</number></property>
