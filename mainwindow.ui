      <widget class="QWidget" name="pageStudentDash">
       <layout class="QVBoxLayout"><property name="margin"><number>12</number></property>
        <item>
         <layout class="QHBoxLayout">
          <item><widget class="QLabel" name="lblStudentWelcome"><property name="text"><string>👋 Welcome</string></property><property name="styleSheet"><string>font-size:14px;font-weight:bold;color:#60a5fa;</string></property></widget></item>
          <item><spacer><property name="orientation"><enum>Qt::Horizontal</enum></property></spacer></item>
          <item><widget class="QPushButton" name="btnStudentLogout"><property name="text"><string>Logout</string></property><property name="maximumSize"><size><width>100</width><height>32</height></size></property></widget></item>
         </layout>
        </item>
        <item>
         <widget class="QTabWidget" name="tabStudent">

          <!-- Profile -->
          <widget class="QWidget" name="tabProfile"><attribute name="title"><string>👤 Profile</string></attribute>
           <layout class="QVBoxLayout"><property name="margin"><number>12</number></property>
            <item><widget class="QPushButton" name="btnViewProfile"><property name="text"><string>👁 View My Full Profile</string></property></widget></item>
            <item>
             <widget class="QGroupBox"><property name="title"><string>Edit Profile (Department / Semester / Phone / CGPA only)</string></property>
              <layout class="QGridLayout">
               <item row="0" column="0"><widget class="QLabel"><property name="text"><string>Department</string></property></widget></item>
               <item row="0" column="1"><widget class="QLineEdit" name="txtStudEditDept"><property name="placeholderText"><string>e.g. CSE</string></property></widget></item>
               <item row="1" column="0"><widget class="QLabel"><property name="text"><string>Semester</string></property></widget></item>
               <item row="1" column="1"><widget class="QLineEdit" name="txtStudEditSem"><property name="placeholderText"><string>e.g. 6th</string></property></widget></item>
               <item row="2" column="0"><widget class="QLabel"><property name="text"><string>Phone</string></property></widget></item>
               <item row="2" column="1"><widget class="QLineEdit" name="txtStudEditPhone"><property name="placeholderText"><string>01XXXXXXXXX</string></property></widget></item>
               <item row="3" column="0"><widget class="QLabel"><property name="text"><string>CGPA</string></property></widget></item>
               <item row="3" column="1"><widget class="QLineEdit" name="txtStudEditCGPA"><property name="placeholderText"><string>e.g. 3.80</string></property></widget></item>
              </layout>
             </widget>
            </item>
            <item><widget class="QPushButton" name="btnStudentSaveProfile"><property name="text"><string>💾 Save Profile</string></property></widget></item>
            <item>
             <widget class="QGroupBox"><property name="title"><string>Change Password</string></property>
              <layout class="QHBoxLayout">
               <item><widget class="QLineEdit" name="txtStudOldPw"><property name="placeholderText"><string>Current password</string></property><property name="echoMode"><enum>QLineEdit::Password</enum></property></widget></item>
               <item><widget class="QLineEdit" name="txtStudNewPw"><property name="placeholderText"><string>New password</string></property><property name="echoMode"><enum>QLineEdit::Password</enum></property></widget></item>
               <item><widget class="QPushButton" name="btnStudentChangePassword"><property name="text"><string>🔑 Change</string></property></widget></item>
              </layout>
             </widget>
            </item>
            <item><spacer><property name="orientation"><enum>Qt::Vertical</enum></property></spacer></item>
           </layout>
          </widget>

          <!-- Groups -->
          <widget class="QWidget" name="tabStudentGroups"><attribute name="title"><string>👥 Groups</string></attribute>
           <layout class="QVBoxLayout"><property name="margin"><number>10</number></property>
