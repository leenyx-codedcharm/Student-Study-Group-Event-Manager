               <item row="1" column="1"><widget class="QLineEdit" name="txtCourseName"><property name="placeholderText"><string>e.g. Data Structures</string></property></widget></item>
               <item row="2" column="0"><widget class="QLabel"><property name="text"><string>Course Code</string></property></widget></item>
               <item row="2" column="1"><widget class="QLineEdit" name="txtCourseCode"><property name="placeholderText"><string>e.g. CSE225</string></property></widget></item>
