            <item><widget class="QPushButton" name="btnAdminCreateTask"><property name="text"><string>➕ Assign Task</string></property></widget></item>
            <item>
             <layout class="QHBoxLayout">
              <item><widget class="QLabel"><property name="text"><string>Task ID:</string></property></widget></item>
